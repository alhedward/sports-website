resource "aws_dynamodb_table" "tournaments" {
  name         = "${local.name_prefix}-tournaments"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "id"

  attribute {
    name = "id"
    type = "S"
  }

  point_in_time_recovery {
    enabled = true
  }

  tags = local.common_tags
}

